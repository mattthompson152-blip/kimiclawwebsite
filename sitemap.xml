---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <!-- Homepage -->
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <priority>1.0</priority>
  </url>
  
  <!-- Main Pages -->
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/online-singing-lessons/</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <priority>0.9</priority>
  </url>
  
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/about/</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <priority>0.8</priority>
  </url>
  
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/celebrity-vocal-coach/</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <priority>0.8</priority>
  </url>
  
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/faq/</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <priority>0.8</priority>
  </url>
  
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/contact/</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <priority>0.9</priority>
  </url>
  
  <!-- Service Pages -->
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/beginner-singing-lessons/</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <priority>0.7</priority>
  </url>
  
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/virtual-singing-lessons/</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <priority>0.7</priority>
  </url>
  
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/remote-singing-lessons/</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <priority>0.7</priority>
  </url>
  
  <!-- Legal Pages -->
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/terms/</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <priority>0.5</priority>
  </url>
  
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/privacy/</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <priority>0.5</priority>
  </url>
  
  <!-- Download Page -->
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/downloads/vocal-warmups-guide/</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <priority>0.6</priority>
  </url>
  
  <!-- Blog Posts -->
  {% for post in site.posts %}
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}{{ post.url }}</loc>
    <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
    <priority>0.8</priority>
  </url>
  {% endfor %}
  
  <!-- Blog Index -->
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/blog/</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <priority>0.8</priority>
  </url>
</urlset>
